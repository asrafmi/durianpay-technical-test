{
  "name": "durianpay-technical-test",
  "version": "1.0.0",
  "description": "DurianPay payment dashboard - Go backend + Vue frontend",
  "private": true,
  "scripts": {
    "install:dependencies": "npm run backend:setup && npm run frontend:install",
    "backend:setup": "cd backend && cp -n env.sample .env || true && make tool-openapi && make openapi-gen && make dep && make gen-secret",
    "frontend:install": "cd frontend && npm install",
    "start:backend:dev": "cd backend && make run",
    "start:frontend:dev": "cd frontend && npm run dev",
    "start:all:dev": "concurrently \"npm run start:backend:dev\" \"npm run start:frontend:dev\"",
    "build:backend": "cd backend && make build",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build:backend && npm run build:frontend",
    "test:backend": "cd backend && go test ./...",
    "test:frontend": "cd frontend && npm run test",
    "test:all": "npm run test:backend && npm run test:frontend",
    "docker:backend": "docker compose -f backend/build/docker/docker-compose.yml",
    "docker:backend:build": "npm run docker:backend -- build",
    "docker:backend:up": "npm run docker:backend -- up -d",
    "docker:backend:down": "npm run docker:backend -- down",
    "docker:backend:logs": "npm run docker:backend -- logs -f backend",
    "docker:frontend": "docker compose -f frontend/build/docker/docker-compose.yml",
    "docker:frontend:build": "npm run docker:frontend -- build",
    "docker:frontend:up": "npm run docker:frontend -- up -d",
    "docker:frontend:down": "npm run docker:frontend -- down",
    "docker:frontend:logs": "npm run docker:frontend -- logs -f frontend",
    "docker:build": "concurrently \"npm run docker:backend:build\" \"npm run docker:frontend:build\"",
    "docker:up": "npm run docker:backend:up && npm run docker:frontend:up",
    "docker:down": "concurrently \"npm run docker:backend:down\" \"npm run docker:frontend:down\"",
    "docker:logs": "concurrently \"npm run docker:backend:logs\" \"npm run docker:frontend:logs\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
